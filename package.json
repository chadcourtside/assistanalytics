{
  "name": "assistanalytics",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "pages:dev": "npm run build && wrangler pages dev dist --d1 DB=assistanalytics",
    "db:migrate:local": "wrangler d1 execute assistanalytics --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute assistanalytics --remote --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "html2pdf.js": "^0.10.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
